    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const nombreCampoBinario = 'Plantilla_HTML'; \n  if (item.binary && item.binary[nombreCampoBinario]) {\n    const datosBase64 = item.binary[nombreCampoBinario].data;\n    const textoHtml = Buffer.from(datosBase64, 'base64').toString('utf-8');\n    item.json.contenido_html = textoHtml;\n  } else {\n    item.json.contenido_html = \"No se encontró ningún archivo.\";\n  }\n}\nreturn $input.all();"
      },
