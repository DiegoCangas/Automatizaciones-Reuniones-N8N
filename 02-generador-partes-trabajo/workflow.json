        },
        "messages": {
          "values": [
            {
              "content": "=\"Analiza el siguiente texto sobre el estado de un proyecto y extrae la información en formato JSON.\n\nInstrucciones de categorización:\nAnaliza todas las tareas o peticiones mencionadas y agrúpalas en categorías lógicas que tú mismo deduzcas según su naturaleza. Usa títulos claros y profesionales en mayúsculas (por ejemplo: 'BUGS CRÍTICOS Y BLOQUEANTES', 'MEJORAS DE RENDIMIENTO', 'AJUSTES DE JUGABILIDAD', 'UI/UX', etc.).\n\nDevuelve ÚNICAMENTE un objeto JSON con la siguiente estructura exacta:\n\nproyecto (string)\n\nversion_periodo (string)\n\nfecha_revision (string)\n\ncategorias (array de objetos). Cada objeto de categoría debe tener:\n\ntitulo (string, en mayúsculas)\n\ntareas (array de objetos). Cada tarea debe tener descripcion (string) y estado (string: 'hecho', 'revisar', 'pendiente', o 'n/a').\"",
              "role": "model"
            },
            {
              "content": "={{ $json.fuente[0] }}"
            }
          ]
        },
        "jsonOutput": true,
        "options": {}
